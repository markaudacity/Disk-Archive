      *= $ц000            ; сTART ADDRESS                          ; бALL аNIMATION                          ; иNTERRUPT DEMO      сеи                 ; сET иNTERRUPT дISABLE фLAG       лда #<невиря        ; цHANGE иря рам VECTOR      ста $0314      лда #>невиря      ста $0315      цли                 ; цLEAR иNTERRUPT дISABLE фLAG      лдь #$10            ; сET сPRITE лOCATION рEGISTERS илооп      лда сп,ь            ; ($д000-д010) SET TO INITIAL VALUES      ста $д000,ь         ; фROM TABLE сп       деь      бпл илооп      лдь #$07            ; сET сPRITE цOLOR рEGISTERS цлооп      лда сц,ь            ; ($д027-д02е) TO VALUES IN TABLE сц      ста $д027,ь      лда #$0б            ; AND сPRITE пOINTERS ($07ф8-$07фф)      ста $07ф8,ь         ; TO SPRITE BLOCK 11      деь      бпл цлооп      лда #0              ; иNITIALIZE OTHER жиц REGISTERS      ста $д017           ; ь-EXPAND      ста $д01ц           ; мULTICOLOR      ста $д01д           ; ы-EXPAND      ста $д020           ; бORDER цOLOR (бLACK)      ста $д021           ; бACKGROUND цOLOR (бLACK)      лда #$фф      ста $д015           ; сPRITE еNABLE рEGISTER      лдь #$3ф            ; пUT сPRITE дATA IN бLOCK 11                          ; ($02ц0-$02фф)слооп      лда балл,ь          ; дATA IN тABLE балл      ста $02ц0,ь      деь      бпл слооп      йср еьп             ; (фOR FURTHER EXPANSION)      ртс                 невиря      ноп                 ; (фOR FURTHER EXPANSION)      ноп      нопцонт     лдь #$0ф             ; сET ь TO $0ф - END OF сPRITE                          ; пOSITIONмлооп     тьа                  ; мAIN LOOP - SAVE BIT 0                          ; (0=ь VALUE, 1=ы VALUE)      лср                 ; пUT IN цARRY фLAG      пхп                 ; сAVE цARRY фLAG      таы                 ; сET мASK бIT FOR мсб REGISTER ($д010)      сец      лда #0блооп      рол      деы      бпл блооп      таы                 ; сTORE мASK IN ы REGISTER      плп                 ; рETRIEVE цARRY фLAG (бIT 0)      лда сд,ь            ; гET DIRECTION OF CORRESPONDING                          ; POSITION REGISTER      бпл регинц          ; иF INCREASING, GO TO рецинц      дец $д000,ь         ; дECREASE VALUE OF POSITION REGISTER      бне неьт            ; иF > 0 THEN DO NEXT REGISTER      бцс неьт            ; иF A ы-POSITION, THEN DO NEXT                          ; REGISTER      тыа                 ; гET мсб REGISTER MASK      еор $д010           ; тOGGLE APPROPRIATE BIT OF мсб REGISTER      ста $д010      тыа                 ; гET мсб MASK AGAIN      анд $д010           ; тEST APPROPRIATE BIT OF мсб REGISTER      бея неьт            ; иF NOT SET THEN DO NEXT REGISTER      лда #$5б            ; лOAD а WITH $5б (91), пUT IN ь POSITION      ста $д000,ь         ; рEGISTER IF SPRITE WRAPS AROUND                          ; LEFT SIDE       ймп неьт            ; нEXT REGISTERрегинц       инц $д000,ь         ; иNCREASE VALUE OF POSITION REGISTER      бцс неьт            ; иF A ы POSITION, DO NEXT REGISTER      бне цхецкь          ; иF NOT 0 CHECK RIGHT EDGE OF SCREEN      тыа                 ; гET MASK BIT      ора $д010           ; сET мсб      ста $д010      ймп неьт            ; дO NEXT REGISTERцхецкь      лда $д000,ь         ; гET CURRENT ь POSITION      цмп #$5б            ; цOMPARE TO $5б (91)      бне неьт            ; иF NOT 91 THEN DO NEXT REGISTER      тыа                 ; гET MASK      анд $д010           ; тEST мсб REGISTER      бея неьт            ; иF NOT AT RIGHT EDGE, DO                          ; NEXT REGISTER      лда #0              ; пUT SPRITE AT LEFT EDGE      ста $д000,ь      тыа      еор $д010      ста $д010неьт      деь                 ; дECREMENT ь - POINT TO NEXT POSITION                          ; REGISTER      бпл млооп           ; иF NOT DONE, DO AGAIN      ймп $еа31           ; гO TO кернал иря ROUTINEсп      .быте 155 90 205 95 255 130 250 175      ; иNITIAL                                               ; POSITIONS      .быте 205 205 155 210 110 170 105 135 0сц      .быте 8 9 10 11 12 13 14 15              ; сPRITE COLORSсд      .быте 0 128 128 0 128 128 128 0          ; дIRECTION      .быте 0 0 128 128 0 128 0 0              ; 0=инц, 128=децбалл      .быте 0 0 0 1 255 128 7 31               ; сPRITE дATA      .быте 224 12 255 240 31 255 248 63      .быте 15 252 126 15 254 124 15 254      .быте 248 112 63 248 240 255 248 255      .быте 255 248 240 255 248 112 63 124      .быте 15 254 126 15 254 63 15 252      .быте 31 255 248 15 255 48 7 248      .быте 224 1 255 128 0 0 0 0еьп      ртс 