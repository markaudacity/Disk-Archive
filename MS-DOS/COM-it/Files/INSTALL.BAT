echo off
cls
rem Install.Bat -- installs COMit on your hard disk
rem Expects the first parameter to be the target drive and directory

Echo ± COMit installation ...
if "%1"=="" goto Error
if not exist %1\NUL mkdir %1
if not exist %1\NUL goto Error
echo ±
echo ± Copying COMit files to %1
echo ±

for %%f in (*.*) do echo %%f
Echo Copying Nine Files to %1
copy comit.exe %1
if not exist %1\comit.exe goto NoInstall
echo Copying 2nd file....
copy help.exe %1
if not exist %1\help.exe goto NoInstall
echo Copying 3rd file....
copy comit.h! %1
if not exist %1\comit.h! goto NoInstall
echo Copying 4th file....
copy comith.bat %1
if not exist %1\comith.bat goto NoInstall
echo Copying 5th file....
copy comithp.bat %1
if not exist %1\comithp.bat goto NoInstall
echo Copying 6th file....
copy readme.bat %1
if not exist %1\readme.bat goto NoInstall
echo Copying 7th file....
copy install.bat %1
if not exist %1\install.bat goto NoInstall
echo Copying 8th file....
copy manual.exe %1
if not exist %1\manual.exe goto NoInstall
echo Copying 9th file....
copy Menu_key.bat %1
if not exist %1\menu_key.bat goto NoInstall
echo done...
goto NoError
:NoInstall
echo ±
echo ± Not all files were installed.  Disk full or File missing?
goto Error
:Error
echo ±
echo ±
echo ± Put the COMit disk in drive "A" or "B".  From the DOS prompt...
echo ±
echo ± Type a valid drive and pathname, eg: INSTALL C:\COMIT
echo ± Note: If the directory does not exist, it will be created.
echo ±
echo ± Or, you can enter just the drive if you want to make a
echo ± backup floppy, eg: INSTALL B:
echo ± this will make a backup copy on drive "B"
echo ±
:Failed
echo ±       
echo ±               ====--- COMit  not installed ---====
echo ±
echo ±    Please follow the instructions above. If you get this message
echo ±    after using the above instructions, consult your DOS manual
echo ±    and use the "COPY" command to transfer the files to your hard disk.
echo ±
echo ±
goto Done
:NoError
cls
echo ±
echo ±  COMit successfully copied.
echo ±
echo ±  Choices:
echo ±            COMIT [Enter]      (COMit, with No Help)
echo ±            HELP [Enter]       (Help by itself)
echo ±            README [Enter]     (The readme file)
echo ±            COMITH [Enter]     (COMit, with [Alt-Z] for Help)
echo ±
echo ±
echo ±                   =====----  N O T E  ----=====
echo ±
echo ±       The COMit Menu key is set at "/" (FORWARD SLASH) as a default.
echo ±       You can change this key by going to the "SETUP" menu
echo ±       after starting COMit and selecting the "F" (F KEYS) option.
echo ±       It's the last entry on that page.
echo ±
echo ±  Change your drive and directory to ====--- " %1 "
echo ±  Then enter one of the above choices.
echo ±
:Done
