*=$ц000; ****аларм цлоцк****; тод цлоцкЮалармЮдемо;      сеи                ; сET иNTERRUPT дISABLE фLAG      Юлда #<невиря      ; цHANGE рам иря жECTOR      ста $0314               лда #>невиря      ста $0315      цли                ; цLEAR иNTERRUPT дISABLE фLAG      ртс невиря      бит $дц0б           ; тEST ам/пм FLAG      бми пм              ; иF NOT пм...      лда #$81            ; гET A REVERSE "а"      бне апфлаг          ; йUMP AHEADпм      лда #$90            ; гET A REVERSE "п"апфлаг      ста $0427           ; пUT CHARACTER IN UPPER LEFT CORNER      лда $дц0б        Ю  ; гET FIRST DIGIT OF хоурс      анд #$10            ;       бея хоур0           ; цHECK IF IT IS "0"      лда #$б1            ; гET A REVERSE "1"      бне д1х             ; йUMP AHEADхоур0      лда #$б0            ; гET A REVERSE "0"д1х      ста $041д           ; пUT UP FIRST DIGIT ON SCREEN      лда $дц0б        Ю  ; гET SECOND DIGIT OF хоурс      анд #$0ф            ; мASK OUT BITS 4-7      ора #$б0            ; аDD ON #$б0 TO GET REVERSE NUMBER      ста $041е           ; пUT UP SECOND DIGIT      лда #$ба            ; гET A REVERSE ":"      ста $041ф           ; пUT ON SCREEN      лда $дц0а           ; гET FIRST DIGIT OF минутес      анд #$70            ; сAVE BITS 4-6      лср                 ; сHIFT RIGHT 4 BITS      лср       лср       лср       ора #$б0            ; гET REVERSE CHARACTER      ста $0420      лда $дц0а           ; GET SECOND DIGIT OF минутес      анд #$0ф      ора #$б0      ста $0421      лда #$ба      ста $0422      лда $дц09           ; дO THE SAME FOR сецондс      анд #$70      лср       лср       лср       лср       ора #$б0      ста $0423      лда $дц09      анд #$0ф      ора #$б0      ста $0424      лда #$ае            ; гET A REVERSE "."      ста $0425           ; пUT ON THE SCREEN      лда $дц08           ; гET тENTH OF SECONDS      анд #$0ф      ора #$б0      ста $0426           ; пUT ON SCREEN      лда $дц0д           ; цHECK ицр IF INTERRUPT                           ;   IS FROM THE аLARM      анд #$84            ; цHECK BITS 7 AND 2      цмп #$84      бея аларм           ; иF BOTH ARE SET, SOUND ALARM      ймп $еа31           ; гO TO кернал иря ROUTINEаларм      лдь #$10            ; сETUP FOR аLARM (16 LOOPS)     Юлды #$00            ; сET дELAY цOUNTERS     Юсты $02     Юлда #$20            ; сET UP сид CHIP     Юста $д400           ; фрея лO     Юста $д401           ; фREQ хI      лда #$0ф      ста $д418           ; жOLUME      лда #$00      ста $д406           ; с/р      лда #$29      ста $д405           ; а/далооп1      лда #$11            ; мAIN аLARM лооп      ста $д404           ; тURN ON тRIANGLE вAVEFORMалооп2      деы                 ; дELAY лооп      бне алооп2      дец $02      бне алооп2      дец $д020    Ю      ; дECREMENT BORDER COLOR      дец $д021           ; дECREMENT BACKGROUND COLOR      лда #$10            ; тURN OFF VOICE 1      ста $д404      деь                 ; дECREMENT лооп COUNTER      бне алооп1          ; иF NOT DONE, DO IT AGAIN      пла                 ; рESTORE REGISTERS FROM THE STACK      таы       пла       таь       пла       рти                 ; рETURN TO PROGRAM 