;модифиед флыинг баллс - боунцинг баллс;витх растер цомпаре генератед интеррупт;анд сприте то форегроунд цоллисион детецтион;еьп      лда #$1б            ;иNITIALIZE жиц-ии REGISTERS      ста $д011           ;цONTROL рEGISTER - 8TH BIT OF                          ;рASTER цOMPARE      лда #0      ста $д012           ;рASTER цOMPARE рEGISTER      лда #$03      ста $д01а           ;иNTERRUPT еNABLE - ерст AND ембц      ста $дц0д           ;тURN OFF тIMER а INTERRUPT FROM циа 1      ртсицхецк      лда $д019           ;гET иNTERRUPT фLAG рEGISTER      анд #$02            ;цHECK IF имбц HAS OCCURRED      бне цоллисион       ;иF ыес - THEN GO TO COLLISION ROUTINE      лда #$01            ;иF но - тURN OFF рASTER цOMPARE лATCH      ста $д019      лда $д01ф           ;цLEAR сPRITE - фOREGROUND                          ;цOLLISION рEGISTER      ймп цонт            ;йUMP TO BALL ANIMATION ROUTINEцоллисион      лда $д01ф           ;гET сPRITE TO фOREGROUND                          ;цOLLISION рEGISTER      лды #$07            ;сET ы TO 7 - сPRITE нUMBER пOINTER      лдь #$00            ;сET ь TO 0 - сPRITE цOLLISION пOINTERсхифт      асл                 ;цHECK IF COLLISION OCCURRED                          ;WITH сPRITE ы      бцц ноцолл          ;иF но - TRY NEXT сPRITE      пха                 ;иF ыес -      тыа      ста цсприте,ь       ;сAVE сPRITE нUMBER      пла      инь                 ;иNCREMENT сPRITE цOLLISION пOINTERноцолл      деы                 ;дECREMENT сPRITE нUMBER пOINTER      бпл схифт           ;иF NOT ALL SPRITES CHECKED,                          ;DO NEXT ONE      деь                 ;пOINT TO LAST SPRITE                          ;COLLISION DETECTEDнеьта       лда цсприте,ь       ;гET сPRITE нUMBER      таы                 ;пUT сн IN ы      пха                 ;сAVE сн TO THE сTACK      лда маск,ы          ;гET мсб MASK FOR сPRITE      ста $фе             ;сTORE IN ZERO PAGE LOCATION $фе      пла                 ;гET сн BACK OFF STACK      асл                 ;мULTIPLY BY 2      таы                 ;пUT NEW POINTER IN ы      лда $д000,ы         ;гET ь LOCATION OF сPRITE      пха                 ;сAVE TO THE сTACK      цмп #$1ц            ;цHECK IF COLLISION IS AT LEFT BORDER      бцс нотлефт         ;иF NOT CHECK RIGHT SIDE      лда $фе             ;гET мсб MASK - цHECK мсб                          ;рEGISTER TO MAKE      анд $д010           ;SURE сPRITE IS AT THE LEFT SIDE      бне нотлефт         ;иF но THEN CHECK RIGHT SIDE      лда #0              ;цHANGE ь DIRECTION OF сPRITE      ста сд,ы            ;сAVE TO сPRITE дIRECTION DATAнотлефт      пла                 ;гET ь LOCATION BACK FROM STACK      цмп #$3д            ;цHECK IF AT RIGHT BORDER      бцц нотригхт        ;иF но - CHECK TOP OF SCREEN      лда $фе             ;гET мсб MASK      анд $д010           ;цHECK мсб BIT      бея нотригхт        ;иF NOT AT RIGHT - CHECK TOP OF SCREEN      лда #$80            ;цHANGE ь DIRECTION OF сPRITE      ста сд,ы            ;сAVE TO сPRITE дIRECTION DATAнотригхт      ины                 ;пOINT TO ы VALUE OF сPRITE лOCATION      лда $д000,ы         ;гET ы VALUE OF сPRITE лOCATION      цмп #$35            ;цHECK IF AT TOP BORDER      бцс ноттоп          ;иF но - THEN CHECK BOTTOM OF SCREEN      лда #0              ;цHANGE сPRITE ы дIRECTION      ста сд,ыноттоп      цмп #$е2            ;цHECK IF AT BOTTOM BORDER      бцц нотботтом       ;иF но - лEAVE      лда #$80            ;цHANGE сPRITE ы дIRECTION      ста сд,ынотботтом      деь                 ;дECREMENT сPRITE цOLLISION пOINTER      бпл неьта           ;иF MORE SPRITES - цHECK NEXT SPRITE      лда #$02            ;цLEAR сPRITE TO фOREGROUND                          ;иNTERRUPT лATCH      ста $д019      ймп $еа81           ;йUMP TO кернал иря EXIT ROUTINEцсприте      .быте 0 0 0 0 0 0 0 0 ;сPRITES THAT COLLIDEDмаск      .быте 1 2 4 8 16 32 64 128 ;мASK VALUES 