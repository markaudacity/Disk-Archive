;нми роутине демо;усинг тимерс а & б оф циа2;еьп      лда #<невнми        ;цHANGE рам нми жECTOR      ста $0318      лда #>невнми      ста $0319      лда #$фф            ;сET UP циа2 REGISTERS      ста $дд04           ;тIMER а ло      ста $дд05           ;тIMER а хи      лда #$2ф      ста $дд06           ;тIMER б ло      лда #$00      ста $дд07           ;тIMER б хи      лда #$51      ста $дд0ф           ;црб - тIMER б COUNTS тIMER а      лда #$11      ста $дд0е           ;цра - тIMER а COUNTS CLOCK CYCLES      лда #$82      ста $дд0д           ;ицр - еNABLE тIMER б INTERRUPTS      ртсневнми      сеи                 ;нEW нми ROUTINE: сET                          ;INTERRUPT DISABLE      пха                 ;сAVE рEGISTERS .а, .ь, ,                          ;AND .ы TO STACK      тьа      пха      тыа      пха      лда $дд0д           ;цHECK ицр TO SEE IF INTERRUPT                          ;IS FROM циа2      бпл ресторе         ;иF NOT GOT TO кернал ROUTINE      лды #$0ф            ;рOTATE DIRECTION VECTORS OF THE BALLS      лдь #$0е      лда $ц0д7           ;сAVE LAST VALUE TO STACK      пхадлооп      лда сд,ь            ;пUSH OTHER VALUES UP ONE      ста сд,ы      деы                 ;дO NEXT VALUE      деь      бпл длооп           ;цHECK IF DONE      пла                 ;гET LAST VALUE FROM STACK      ста сд              ;пUT AT THE BEGINNING      ймп $фебц           ;йUMP OUT THROUGH кернал нми EXITресторе      ймп $фе4ц           ;йUMP TO ресторе KEY ROUTINE 