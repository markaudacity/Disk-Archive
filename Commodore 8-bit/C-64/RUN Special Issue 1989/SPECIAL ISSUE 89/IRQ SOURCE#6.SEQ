*= $ц000;;       тхе схакинг сцреен; ***** растер цомпаре демо *****;      сеи                 ;сET иNTERRUPT дISABLE фLAG      лда #<невиря        ;цHANGE иря рам жECTOR      ста $0314      лда #>невиря      ста $0315      цли                 ;цLEAR иNTERRUPT дISABLE фLAG      лда #$00            ;иNTIALIZE COUNTERS AND жиц-ии CHIP      ста $02             ;сET POINTER TO ZERO      ста $д012           ;сET рASTER цOMPARE FOR SCAN LINE 0      лда #$1б      ста $д011           ;сET TOP BIT TO 0      лда #$01      ста $д01а           ;еNABLE рASTER цOMPARE иNTERRUPT      ста $дц0д           ;дISABLE тIMER а INTERRUPT FROM циа 1      ртсневиря      лдь $д012           ;гET VALUE OF CURRENT SCAN LINE      бне нормал          ;иF NOT AT SCAN LINE 0 NORMAL DISPLAYсхифт      лды $02             ;гET POINTER TO FINE SCROLL DATA      ины                 ;иNCREMENT POINTER      цпы #$0е            ;иF AT END OF DATA ...      бне геты      лды #$00            ;... THEN START AGAINгеты      лда ыс,ы            ;гET FINE SCROLL DATA      ста $д016           ;пUT IN HORIZONTAL FINE SCROLL                          ;REGISTER      сты $02             ;сAVE POINTER      лда #$01      ста $д019           ;рESET рASTER цOMPARE иNTERRUPT лATCH      лда #$9а            ;лOAD VALUE OF NEXT рASTER                          ;цOMPARE (154)      ста $д012           ;сAVE TO рASTER цOMPARE рEGISTER      ймп $еа81           ;еXIT INTERRUPT ROUTINE THROUGH                          ;THE керналнормал      лда #$08            ;сET FINE SCROLL TO 0      ста $д016           ;сAVE TO HORIZONTAL FINE                          ;SCROLL REGISTER      лда #$01      ста $д019           ;рESET рASTER цOMPARE иNTERRUPT лATCH      лда #$00            ;лOAD VALUE OF NEXT рASTER цOMPARE (0)      ста $д012           ;сAVE TO рASTER цOMPARE рEGISTER      ймп $еа31           ;йUMP TO кернал иря ROUTINEыс      .быте 8 9 10 11 12 13 14 15  ;фINE SCROLL DATA      .быте 14 13 12 11 10 9 